# 忽略Python缓存文件
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境
venv/
env/
.venv/

# 忽略IDE配置
.vscode/
.idea/
*.swp
*.swo

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略日志文件
*.log

# 忽略Windows设备名文件
nul
nul.*

# 忽略临时文件
*.tmp

# 运行时产物 - 不应提交到仓库
monitor.db
run_log.jsonl
fast_log.jsonl
rss_history.json

# 大数据文件 - 已迁移到 GitHub Gist 存储
# 前端通过 items_ref.json 中的 Gist URL 加载数据
# items.json 和 items_latest.json 已移除 gitignore，需要持久化到仓库
# items.json
# items_latest.json
notified_items.json

# 邮件备份 - 一次性快照，不再维护
email_backup/

# 空目录占位
data/.gitkeep
